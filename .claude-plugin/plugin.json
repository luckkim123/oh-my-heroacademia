{
  "name": "oh-my-heroacademia",
  "description": "Meta-orchestration harness. Routes each request to the right lane (superpowers / oh-my-claudecode / handle-directly) via a UserPromptSubmit hook that reads declarative harness cards.",
  "author": { "name": "kimseungmin" },
  "license": "MIT",
  "keywords": ["claude-code", "plugin", "routing", "orchestration", "meta"],
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/route_emit.py"]
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/cross_lane_emit.py"]
          }
        ]
      },
      {
        "matcher": "Bash|Agent|Task|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/route_guard.py"]
          }
        ]
      },
      {
        "matcher": "Bash|mcp__github__create_pull_request|mcp__github__create_or_update_file",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/redact_guard.py"]
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/route_stop_guard.py"]
          }
        ]
      }
    ]
  }
}
